{% extends 'base.twig' %}

{% block content %}
{% include 'partials/no-hero.twig' %}

<div class="w-full xl:container mx-auto px-6 pt-4 lg:pt-12 pb-16" id="content" tabindex="-1">
	<article class="{{ post_class }}" id="post-{{ post_id }}">
		<header>
			<h1 class="entry-title font-sans uppercase font-semibold text-gray-700 mb-4 text-3xl lg:text-4xl">
				{{ employee_title }}
				{% if pronouns %}
					<span class="lowercase">({{ pronouns }})</span>
				{% endif %}
				{% if not hide_profile %}
					Profile
				{% endif %}
			</h1>
		</header>

		<div class="entry-content">
			<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

				{# Left column: headshot, contact details, social #}
				<div class="lg:col-span-1">
					{% if headshot %}
						<img src="{{ headshot.src }}" srcset="{{ headshot.srcset }}" alt="{{ headshot.alt }}" class="rounded-lg" />
					{% endif %}

					<div class="mt-6 mb-8">
						{% if position %}
							<div class="my-2 text-lg font-semibold">{{ position }}</div>
						{% endif %}
						{% if departments_html %}
							{{ departments_html|raw }}
						{% endif %}
					</div>

					{% if office_location %}
						<div class="flex items-start my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4 mt-1" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
							{{ office_location }}
						</div>
					{% endif %}

					{% if phone %}
						<div class="flex items-center my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg>
							{{ phone }}
						</div>
					{% endif %}

					{% if email %}
						<div class="flex items-center my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg>
							<a href="mailto:{{ email }}">{{ email }}</a>
						</div>
					{% endif %}

					{% if website %}
						<div class="flex items-center my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
							<a href="{{ website }}">Visit Website</a>
						</div>
					{% endif %}

					{% if more_info %}
						<div class="flex items-center my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 00-2 2v10a2 2 002 2h10a2 2 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
							<a href="{{ more_info }}">More Info</a>
						</div>
					{% endif %}

					{% if bookings_url %}
						<div class="flex items-center my-2">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M1 4c0-1.1.9-2 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V4zm2 2v12h14V6H3zm2-6h2v2H5V0zm8 0h2v2h-2V0zM5 9h2v2H5V9zm0 4h2v2H5v-2zm4-4h2v2H9V9zm0 4h2v2H9v-2zm4-4h2v2h-2V9zm0 4h2v2h-2v-2z"/></svg>
							<a href="{{ bookings_url }}">Book a Meeting</a>
						</div>
					{% endif %}

					{% if cv_url %}
						<div class="flex items-center my-4">
							<svg class="stroke-gray-200 h-5 w-5 mr-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path d="M369.9 97.9L286 14C277 5 264.8-.1 252.1-.1H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V131.9c0-12.7-5.1-25-14.1-34zM332.1 128H256V51.9l76.1 76.1zM48 464V48h160v104c0 13.3 10.7 24 24 24h104v288H48z"></path></svg>
							<a href="{{ cv_url }}">Curriculum Vitae</a>
						</div>
					{% endif %}

					{% if facebook or twitter or linkedin %}
						<div class="flex items-center space-x-4 mt-12">
							{% if facebook %}
								<a href="{{ facebook }}" class="py-2 px-2 text-white bg-green rounded-sm hover:bg-green-dark hover:text-white">
									<svg class="fill-white h-5 w-5 hover:fill-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"></path></svg>
								</a>
							{% endif %}
							{% if twitter %}
								<a href="{{ twitter }}" class="py-2 px-2 text-white bg-green rounded-sm hover:bg-green-dark hover:text-white">
									<svg class="fill-white h-5 w-5 hover:fill-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M459.37 151.716c.325 4.548.325 9.097.325 13.645 0 138.72-105.583 298.558-298.558 298.558-59.452 0-114.68-17.219-161.137-47.106 8.447.974 16.568 1.299 25.34 1.299 49.055 0 94.213-16.568 130.274-44.832-46.132-.975-84.792-31.188-98.112-72.772 6.498.974 12.995 1.624 19.818 1.624 9.421 0 18.843-1.3 27.614-3.573-48.081-9.747-84.143-51.98-84.143-102.985v-1.299c13.969 7.797 30.214 12.67 47.431 13.319-28.264-18.843-46.781-51.005-46.781-87.391 0-19.492 5.197-37.36 14.294-52.954 51.655 63.675 129.3 105.258 216.365 109.807-1.624-7.797-2.599-15.918-2.599-24.04 0-57.828 46.782-104.934 104.934-104.934 30.213 0 57.502 12.67 76.67 33.137 23.715-4.548 46.456-13.32 66.599-25.34-7.798 24.366-24.366 44.833-46.132 57.827 21.117-2.273 41.584-8.122 60.426-16.243-14.292 20.791-32.161 39.308-52.628 54.253z"></path></svg>
								</a>
							{% endif %}
							{% if linkedin %}
								<a href="{{ linkedin }}" class="py-2 px-2 text-white bg-green rounded-sm hover:bg-green-dark hover:text-white">
									<svg class="fill-white h-5 w-5 hover:fill-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path></svg>
								</a>
							{% endif %}
						</div>
					{% endif %}
				</div>

				{# Right column: videos, biography, toggles #}
				<div class="lg:col-span-3">
					{% if youtube_videos %}
						{% if video_section_title %}
							<h2>{{ video_section_title }}</h2>
						{% endif %}
						<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-12">
							{% for video in youtube_videos %}
								<div class="aspect-video">
									<iframe class="h-full w-full" src="https://www.youtube.com/embed/{{ video.youtube_video_id }}" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
								</div>
							{% endfor %}
						</div>
					{% endif %}

					{% if biography %}
						<h2>Biography</h2>
						<div class="mt-4 mb-12">{{ biography|raw }}</div>
					{% endif %}

					{% if toggles_html %}
						{{ toggles_html|raw }}
					{% endif %}
				</div>

			</div>
		</div>
	</article>
</div>
{% endblock %}
